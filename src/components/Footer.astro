/** 解析图标：内置名 / 图片路径 / SVG path / 首字母 */
function resolveIcon(link: { name: string; icon?: string }): { type: 'svg' | 'image' | 'initial'; value: string } {
  const icon = link.icon;
  if (!icon) return { type: 'initial', value: link.name.charAt(0) };
  if (builtinIcons[icon.toLowerCase()]) return { type: 'svg', value: builtinIcons[icon.toLowerCase()] };
  if (icon.startsWith('/') || icon.startsWith('http') || icon.includes('.')) return { type: 'image', value: icon };
  if (/^[Mm]/.test(icon)) return { type: 'svg', value: icon };
  return { type: 'initial', value: link.name.charAt(0) };
}
---

<style is:global>
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: minmax(0, 1.2fr) repeat(var(--footer-cols), max-content);
      gap: 3rem;
    }
  }
  .social-qr-wrap { position: relative; display: inline-flex; }
  .social-qr-popup {
    display: none; position: absolute; bottom: calc(100% + 12px); left: 50%;
    transform: translateX(-50%); background: white; border-radius: 8px;
    padding: 12px; box-shadow: 0 8px 30px rgba(0,0,0,.25); z-index: 60;
    text-align: center; min-width: 140px;
  }
  .social-qr-popup::after {
    content: ''; position: absolute; top: 100%; left: 50%;
    transform: translateX(-50%); border: 6px solid transparent; border-top-color: white;
  }
  .social-qr-wrap:hover .social-qr-popup { display: block; }
  .social-qr-popup img { width: 120px; height: 120px; object-fit: contain; border-radius: 4px; }
  .social-qr-popup .qr-label { font-size: 12px; color: #333; margin-top: 6px; font-weight: 500; }
  .qr-cards-section { margin-top:1rem; }
  .qr-cards-row { display: flex; gap: 1rem; flex-wrap: wrap; }
  .qr-card { text-align: center; }
  .qr-card img { width: 96px; height: 96px; border-radius: 8px; border: 1px solid #334155; background: #fff; padding: 4px; }
  .qr-card .qr-card-label { font-size: 13px; color: #e2e8f0; margin-top: 6px; font-weight: 500; }
  .qr-card .qr-card-desc { font-size: 11px; color: #64748b; margin-top: 2px; }
</style>

<footer class="bg-ink-950 text-ink-300">
  <div class="container-page pt-16">
    <div class="footer-grid" style={`--footer-cols: ${columns.length}`}>
      {/* 品牌区 */}
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 no-underline">
          <img src={seoConfig.logoPath ?? '/favicon.ico'} alt="logo" style={{ height: seoConfig.logoHeight + 'px' || '24px' }} class="rounded-md" loading="eager" fetchpriority="high" />
          {seoConfig.showSiteName && <span class="font-semibold text-white text-lg">{siteConfig.name}</span>}
        </a>
        <p class="text-sm text-ink-300 leading-relaxed">
          {siteConfig.tagline}
        </p>

        {/* 联系信息 */}
        {showContact && contact && (
          <div class:list={[
            'mt-4 text-xs text-ink-400',
            contactLayout === 'horizontal' ? 'flex flex-wrap items-center gap-x-4 gap-y-1.5' : 'space-y-1.5'
          ]}>
            {contact.phone && (
              <div class="flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-ink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                <span>{contact.phone}</span>
              </div>
            )}
            {contact.email && (
              <div class="flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-ink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                <span>{contact.email}</span>
              </div>
            )}
            {contact.wechat && (
              <div class="flex items-center gap-2">
                <span class="text-ink-500">微信:</span>
                <span>{contact.wechat}</span>
              </div>
            )}
          </div>
        )}

        {/* 社交链接 */}
        {socialLinks.length > 0 && (
          <div class="mt-4 flex items-center gap-3 flex-wrap">
            {socialLinks.map((link) => {
              const hasQr = Boolean(link.qrCode);
              const hasIcon = Boolean(link.icon);
              const icon = hasIcon ? resolveIcon(link) : null;
              return (
                <div class:list={[hasQr && 'social-qr-wrap']}>
                  {/* 有链接的用 a，纯二维码展示用 div */}
                  {(link.href && !hasQr) ? (
                    <a href={link.href} target="_blank" rel="noopener noreferrer"
                      class="text-ink-500 hover:text-white transition-colors inline-flex" aria-label={link.name}>
                      {icon?.type === 'svg' && <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d={icon.value} /></svg>}
                      {icon?.type === 'image' && <img src={icon.value} alt={link.name} class="w-5 h-5 rounded" />}
                      {icon?.type === 'initial' && <span class="w-6 h-6 rounded-full bg-ink-700 text-white text-xs flex items-center justify-center font-medium">{icon.value}</span>}
                      {!hasIcon && <span class="text-xs text-ink-400">{link.name}</span>}
                    </a>
                  ) : (
                    <div class="text-ink-500 hover:text-white transition-colors inline-flex cursor-pointer" aria-label={link.name}>
                      {icon?.type === 'svg' && <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d={icon.value} /></svg>}
                      {icon?.type === 'image' && <img src={icon.value} alt={link.name} class="w-5 h-5 rounded" />}
                      {icon?.type === 'initial' && <span class="w-6 h-6 rounded-full bg-ink-700 text-white text-xs flex items-center justify-center font-medium">{icon.value}</span>}
                      {!hasIcon && <span class="text-xs text-ink-400">{link.name}</span>}
                    </div>
                  )}
                  {hasQr && (
                    <div class="social-qr-popup">
                      <img src={link.qrCode!} alt={`${link.name} 二维码`} />
                      <div class="qr-label">{link.qrLabel ?? link.name}</div>
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        )}
        {/* 二维码卡片（直接展示，非 hover） */}
      {qrCards.length > 0 && (
        <div class="qr-cards-section">
          <div class="qr-cards-row">
            {qrCards.map((card) => (
              <div class="qr-card">
                <img src={card.image} alt={`${card.label} 二维码`} />
                <div class="qr-card-label">{card.label}</div>
                {card.description && <div class="qr-card-desc">{card.description}</div>}
              </div>
            ))}
          </div>
        </div>
      )}
      </div>

      {/* 动态链接列 */}
      {columns.map((col) => (
        <div>
          <div class="text-white text-sm font-semibold mb-4">{col.label}</div>
          <ul class="space-y-2 text-sm">
            {col.items.map((item) => {
              const isExt = isExternalLink(item);
              return (
                <li>
                  <a
                    href={item.href}
                    target={isExt ? '_blank' : undefined}
                    rel={isExt ? 'noopener noreferrer' : undefined}
                    class="text-ink-300 hover:text-white no-underline"
                  >
                    {item.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>

      

    <div class="mt-8 py-2 border-t border-ink-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-ink-300">
      <div>&copy; {year > 2026 ? '2026 - ' + year : year } {siteConfig.legalEntity.name}. {i18nConfig.copyright}</div>
      {showFooterCredit && (
        <div class="text-ink-300 leading-relaxed">
          {creditPrefix}
          <a
            href={creditHref}
            target="_blank"
            rel="sponsored noopener noreferrer"
            class="text-white hover:text-brand-200 no-underline color-brand-200"
          >
          {creditLabel}
          </a>
          {creditSuffix}
        </div>
      )}
      <div class="flex items-center gap-4">
        {showLegalLinks && (
          <>
            <a href={footerConfig.privacyHref} class="text-ink-300 hover:text-white no-underline">{i18nConfig.privacy}</a>
            <a href={footerConfig.termsHref} class="text-ink-300 hover:text-white no-underline">{i18nConfig.terms}</a>
          </>
        )}
        {features.icpBeian && siteConfig.beian?.icp && (
          <a href={siteConfig.beian.icpUrl} target="_blank" rel="noopener" class="text-ink-300 hover:text-ink-200 no-underline">{siteConfig.beian.icp}</a>
        )}
      </div>
    </div>
  </div>
</footer>
