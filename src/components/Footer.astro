---
import { siteConfig, navConfig, i18nConfig, seoConfig, footerConfig, growthPartnerConfig } from 'virtual:dfgrow/config';
const year = new Date().getFullYear();
const features = seoConfig.features ?? {};

// 合规
const hasAnalytics = Boolean(
  import.meta.env.PUBLIC_GA4_ID || import.meta.env.PUBLIC_CLARITY_ID || import.meta.env.PUBLIC_BAIDU_TONGJI_ID
);
const showLegalLinks = footerConfig.legalLinks !== false || hasAnalytics;

// 动态列
const columns = navConfig.footerColumns ?? [
  { label: navConfig.footerLabels.services, items: navConfig.footer.services },
  { label: navConfig.footerLabels.company, items: navConfig.footer.company },
  { label: navConfig.footerLabels.resources, items: navConfig.footer.resources },
];

const showContact = footerConfig.showContact ?? false;
const contactLayout = footerConfig.contactLayout ?? 'vertical';
const contact = siteConfig.contact;
const socialLinks = footerConfig.socialLinks ?? [];
const qrCards = footerConfig.qrCards ?? [];

/**
 * 判断导航项是否应作为外链在新标签页打开。
 * - item.external === true：强制外链
 * - item.external === false：强制内链（即使 href 是绝对 URL）
 * - undefined：自动判断 —— http:// 或 https:// 开头视为外链
 */
function isExternalLink(item: { href?: string; external?: boolean }): boolean {
  if (item.external === true) return true;
  if (item.external === false) return false;
  return /^https?:\/\//i.test(item.href ?? '');
}

// ── 页脚致谢区块（官网由登峰增长搭建）──
// 仅当客户在 dfgrow.config.ts 中显式设置 growthPartner.footerCredit = true 时展示
const showFooterCredit = growthPartnerConfig.footerCredit === true;
const creditLabel = growthPartnerConfig.footerCreditLabel ?? '登峰增长';
const creditPrefix = growthPartnerConfig.footerCreditPrefix ?? '官网由';
const creditSuffix = growthPartnerConfig.footerCreditSuffix ?? '搭建及提供SEO/GEO优化支持';

const creditBaseHref = growthPartnerConfig.footerCreditHref ?? growthPartnerConfig.primaryHref ?? 'https://dfgrow.com/';
const creditAppendUtm = growthPartnerConfig.appendUtm !== false;
const creditUtmSource = growthPartnerConfig.utm?.source ?? 'sczhiyu';
const creditUtmMedium = growthPartnerConfig.utm?.footerMedium ?? 'footer';
const creditUtmCampaign = 'partner_promo';

function buildCreditHref(baseUrl: string): string {
  if (!creditAppendUtm) return baseUrl;
  try {
    const url = new URL(baseUrl);
    const sp = url.searchParams;
    if (!sp.get('utm_source')) sp.set('utm_source', creditUtmSource);
    if (!sp.get('utm_medium')) sp.set('utm_medium', creditUtmMedium);
    if (!sp.get('utm_campaign')) sp.set('utm_campaign', creditUtmCampaign);
    return url.toString();
  } catch {
    const sep = baseUrl.includes('?') ? '&' : '?';
    return `${baseUrl}${sep}utm_source=${encodeURIComponent(creditUtmSource)}&utm_medium=${encodeURIComponent(creditUtmMedium)}&utm_campaign=${encodeURIComponent(creditUtmCampaign)}`;
  }
}
const creditHref = buildCreditHref(creditBaseHref);

