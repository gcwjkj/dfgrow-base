---
/**
 * 博客文章卡片
 *
 * Props:
 *   post: { slug, data: BlogPostFrontmatter } — 文章内容数据
 *   href?: string — 文章链接（默认 /blog/{slug}）
 *   showCover?: boolean — 是否展示封面图（默认 true）
 *   readingTime?: number — 阅读时间（分钟）
 */
interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      pubDate: Date | string;
      tags?: string[];
      cover?: string;
      coverAlt?: string;
      author?: string;
    };
  };
  href?: string;
  showCover?: boolean;
  readingTime?: number;
}

const { post, showCover = true, readingTime } = Astro.props;
const href = Astro.props.href ?? `/blog/${post.slug}`;
const d = post.data;

function formatDate(date: Date | string): string {
  const dt = typeof date === 'string' ? new Date(date) : date;
  return dt.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<a href={href} class="df-blog-card" data-track="blog_card_click" data-track-slug={post.slug}>
  {showCover && d.cover && (
    <div class="df-blog-card__cover">
      <img src={d.cover} alt={d.coverAlt ?? d.title} loading="lazy" />
    </div>
  )}
  <div class="df-blog-card__body">
    <div class="df-blog-card__meta">
      <time datetime={typeof d.pubDate === 'string' ? d.pubDate : d.pubDate.toISOString()}>
        {formatDate(d.pubDate)}
      </time>
      {readingTime && <span class="df-blog-card__read-time">{readingTime} 分钟阅读</span>}
    </div>
    <h3 class="df-blog-card__title">{d.title}</h3>
    <p class="df-blog-card__desc">{d.description}</p>
    {d.tags && d.tags.length > 0 && (
      <div class="df-blog-card__tags">
        {d.tags.slice(0, 3).map((tag) => (
          <span class="df-blog-card__tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style is:inline>
  .df-blog-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-card, 12px);
    border: 1px solid var(--color-ink-200, #e5e7eb);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
  }
  .df-blog-card:hover {
    border-color: var(--color-brand-300, #93b4f5);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--color-brand-600, #1f44d6) 6%, transparent);
    transform: translateY(-2px);
  }
  .df-blog-card:focus-visible {
    outline: 2px solid var(--color-brand-500, #1f44d6);
    outline-offset: 2px;
  }
  .df-blog-card__cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-ink-100, #f3f4f6);
  }
  .df-blog-card__cover img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.3s ease;
  }
  .df-blog-card:hover .df-blog-card__cover img {
    transform: scale(1.03);
  }
  .df-blog-card__body {
    flex: 1; padding: 1.25rem;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .df-blog-card__meta {
    display: flex; align-items: center; gap: 0.75rem;
    font-size: 0.8125rem; color: var(--color-ink-500, #6b7280);
  }
  .df-blog-card__read-time::before { content: '·'; margin-right: 0.75rem; }
  .df-blog-card__title {
    font-size: 1.0625rem; font-weight: 600; line-height: 1.4;
    color: var(--color-ink-900, #111); margin: 0;
  }
  .df-blog-card__desc {
    font-size: 0.875rem; color: var(--color-ink-600, #4b5563);
    line-height: 1.6; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .df-blog-card__tags {
    display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: auto; padding-top: 0.5rem;
  }
  .df-blog-card__tag {
    font-size: 0.6875rem; padding: 0.125rem 0.5rem;
    background: var(--color-ink-100, #f3f4f6); color: var(--color-ink-600, #4b5563);
    border-radius: 9999px;
  }
</style>
