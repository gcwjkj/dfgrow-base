---
/**
 * 移动端粘性 CTA 底栏
 *
 * 用法：在服务页面引入 <MobileCtaBar href="/contact" label="预约诊断" />
 * 仅在移动端 (max-width: 768px) 显示，桌面端隐藏
 * 底部固定，不遮挡内容（自动添加 body padding-bottom）
 */
interface Props {
  href?: string;
  label?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  href = '/contact',
  label = '预约诊断',
  secondaryLabel,
  secondaryHref,
} = Astro.props;
---

<div class="df-mobile-cta" role="region" aria-label="快速操作">
  <div class="df-mobile-cta__inner">
    {secondaryLabel && secondaryHref && (
      <a href={secondaryHref} class="df-mobile-cta__secondary" data-track="cta_click" data-track-location="mobile_bar_secondary">
        {secondaryLabel}
      </a>
    )}
    <a href={href} class="df-mobile-cta__primary" data-track="cta_click" data-track-location="mobile_bar">
      {label}
    </a>
  </div>
</div>

<style is:inline>
  .df-mobile-cta {
    display: none;
  }

  @media (max-width: 768px) {
    .df-mobile-cta {
      display: block;
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 9000;
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-top: 1px solid var(--color-ink-200);
      padding: 10px 16px calc(10px + env(safe-area-inset-bottom, 0px));
    }

    .df-mobile-cta__inner {
      display: flex;
      gap: 8px;
      max-width: 480px;
      margin: 0 auto;
    }

    .df-mobile-cta__primary {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 12px 20px;
      border-radius: var(--radius-btn);
      background: var(--color-brand-600);
      color: #fff;
      font-size: 15px;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.2s ease;
      white-space: nowrap;
    }
    .df-mobile-cta__primary:active {
      background: var(--color-brand-700);
    }

    .df-mobile-cta__secondary {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 12px 16px;
      border-radius: var(--radius-btn);
      background: #fff;
      color: var(--color-brand-600);
      border: 1px solid var(--color-brand-200);
      font-size: 15px;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.2s ease;
      white-space: nowrap;
    }
    .df-mobile-cta__secondary:active {
      background: var(--color-brand-50);
    }
  }
</style>

<script is:inline>
  // 在移动端自动给 body 添加底部间距，防止 CTA 栏遮挡内容
  (function () {
    function adjustBodyPadding() {
      var bar = document.querySelector('.df-mobile-cta');
      if (!bar) return;
      var isMobile = window.matchMedia('(max-width: 768px)').matches;
      if (isMobile) {
        document.body.style.paddingBottom = '64px';
      } else {
        document.body.style.paddingBottom = '';
      }
    }
    adjustBodyPadding();
    window.addEventListener('resize', adjustBodyPadding);
  })();
</script>
