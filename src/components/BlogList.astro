---
/**
 * 博客列表组件（通用）
 *
 * 渲染文章卡片网格 + 可选的标签筛选栏。
 * 品牌特有内容（作者 Hero、微信二维码等）放在页面层，不在此组件内。
 *
 * Props:
 *   posts: Array<{ id/slug, data: { title, description, pubDate, tags?, cover?, coverAlt? } }>
 *   basePath?: string — 文章链接基础路径（默认 /blog）
 *   showCover?: boolean — 是否显示封面（默认 true）
 *   showFilter?: boolean — 是否显示标签筛选栏（默认 true）
 *   maxTags?: number — 筛选栏最多显示标签数（默认 10）
 *   readingTimes?: Record<string, number> — slug → 阅读时间
 *   formatDate?: (d: Date) => string — 自定义日期格式化
 *   emptyMessage?: string
 */

interface PostItem {
  id?: string;
  slug?: string;
  data: {
    title: string;
    description: string;
    pubDate: Date | string;
    tags?: string[];
    cover?: string;
    coverAlt?: string;
  };
}

interface Props {
  posts: PostItem[];
  basePath?: string;
  showCover?: boolean;
  showFilter?: boolean;
  maxTags?: number;
  readingTimes?: Record<string, number>;
  formatDate?: (d: Date) => string;
  emptyMessage?: string;
}

const {
  posts,
  basePath = '/blog',
  showCover = true,
  showFilter = true,
  maxTags = 10,
  readingTimes,
  emptyMessage = '暂无文章',
} = Astro.props;

const defaultFormatDate = Astro.props.formatDate ?? ((d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
);

// 聚合标签
const tagCount = new Map<string, number>();
posts.forEach((p) => (p.data.tags ?? []).forEach((t) => tagCount.set(t, (tagCount.get(t) || 0) + 1)));
const topTags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]).slice(0, maxTags).map(([t]) => t);

function getSlug(p: PostItem): string {
  return p.id ?? p.slug ?? '';
}

function toDate(d: Date | string): Date {
  return typeof d === 'string' ? new Date(d) : d;
}
---

{topTags.length > 0 && showFilter && (
  <div class="df-blog-filter" id="df-blog-filter">
    <button class="df-blog-filter__btn df-blog-filter__btn--active" data-tag="">全部</button>
    {topTags.map((tag) => (
      <button class="df-blog-filter__btn" data-tag={tag}>{tag}</button>
    ))}
  </div>
)}

<p class="df-blog-filter__status" id="df-blog-filter-status"></p>

{posts.length > 0 ? (
  <div class="df-blog-grid">
    {posts.map((post) => {
      const slug = getSlug(post);
      const d = post.data;
      const rt = readingTimes?.[slug];
      return (
        <a
          href={`${basePath}/${slug}`}
          class="df-blog-card"
          data-tags={JSON.stringify(d.tags ?? [])}
        >
          {showCover && d.cover && (
            <div class="df-blog-card__cover">
              <img src={d.cover} alt={d.coverAlt ?? d.title} loading="lazy" />
            </div>
          )}
          <div class="df-blog-card__body">
            <div class="df-blog-card__meta">
              <time datetime={toDate(d.pubDate).toISOString()}>
                {defaultFormatDate(toDate(d.pubDate))}
              </time>
              {rt != null && <span class="df-blog-card__rt">· {rt} 分钟</span>}
            </div>
            <h3 class="df-blog-card__title">{d.title}</h3>
            <p class="df-blog-card__desc">{d.description}</p>
            {d.tags && d.tags.length > 0 && (
              <div class="df-blog-card__tags">
                {d.tags.slice(0, 3).map((tag) => (
                  <span class="df-blog-card__tag">#{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      );
    })}
  </div>
) : (
  <div class="df-blog-empty">
    <p>{emptyMessage}</p>
  </div>
)}

<style is:inline>
  .df-blog-filter {
    display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem;
  }
  .df-blog-filter__btn {
    padding: 0.5rem 1rem; border-radius: 9999px;
    font-size: 0.75rem; font-weight: 500;
    border: 1px solid var(--color-ink-200, #e5e7eb);
    background: #fff; color: var(--color-ink-500, #6b7280);
    cursor: pointer; transition: all 0.2s ease;
  }
  .df-blog-filter__btn:hover {
    border-color: var(--color-brand-300, #93b4f5);
    color: var(--color-brand-600, #1f44d6);
  }
  .df-blog-filter__btn--active {
    background: var(--color-brand-600, #1f44d6);
    color: #fff; border-color: var(--color-brand-600, #1f44d6);
  }
  .df-blog-filter__status {
    font-size: 0.75rem; color: var(--color-ink-600, #4b5563);
    margin: -0.5rem 0 1rem; display: none;
  }
  .df-blog-filter__status.is-visible { display: block; }

  .df-blog-grid {
    display: grid; grid-template-columns: 1fr; gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .df-blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .df-blog-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .df-blog-card {
    display: flex; flex-direction: column;
    border-radius: var(--radius-card, 12px);
    border: 1px solid var(--color-ink-200, #e5e7eb);
    overflow: hidden; text-decoration: none; color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
  }
  .df-blog-card:hover {
    border-color: var(--color-brand-300, #93b4f5);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--color-brand-600, #1f44d6) 6%, transparent);
    transform: translateY(-2px);
  }
  .df-blog-card:focus-visible {
    outline: 2px solid var(--color-brand-500, #1f44d6);
    outline-offset: 2px;
  }
  .df-blog-card__cover {
    aspect-ratio: 16/9; overflow: hidden;
    background: var(--color-ink-100, #f3f4f6);
  }
  .df-blog-card__cover img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.3s ease;
  }
  .df-blog-card:hover .df-blog-card__cover img { transform: scale(1.03); }

  .df-blog-card__body {
    flex: 1; padding: 1.25rem;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .df-blog-card__meta {
    display: flex; align-items: center; gap: 0.25rem;
    font-size: 0.8125rem; color: var(--color-ink-500, #6b7280);
  }
  .df-blog-card__rt { color: var(--color-ink-400, #9ca3af); }
  .df-blog-card__title {
    font-size: 1.0625rem; font-weight: 600; line-height: 1.4;
    color: var(--color-ink-900, #111); margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .df-blog-card:hover .df-blog-card__title {
    color: var(--color-brand-700, #1a3ab8);
  }
  .df-blog-card__desc {
    font-size: 0.875rem; color: var(--color-ink-600, #4b5563);
    line-height: 1.6; margin: 0; flex: 1;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .df-blog-card__tags {
    display: flex; flex-wrap: wrap; gap: 0.375rem;
    margin-top: auto; padding-top: 0.25rem;
  }
  .df-blog-card__tag {
    font-size: 0.6875rem; padding: 0.125rem 0.5rem;
    background: var(--color-ink-100, #f3f4f6);
    color: var(--color-ink-600, #4b5563);
    border-radius: 9999px;
  }

  .df-blog-empty {
    text-align: center; padding: 3rem 1.5rem;
    color: var(--color-ink-500, #6b7280); font-size: 1rem;
  }
</style>

<script is:inline>
  (function() {
    var filterBar = document.getElementById('df-blog-filter');
    var statusEl = document.getElementById('df-blog-filter-status');
    if (!filterBar) return;
    var btns = filterBar.querySelectorAll('.df-blog-filter__btn');
    var cards = document.querySelectorAll('.df-blog-card');
    var activeTag = '';

    function apply() {
      var visible = 0;
      cards.forEach(function(card) {
        var tags = JSON.parse(card.getAttribute('data-tags') || '[]');
        var match = !activeTag || tags.indexOf(activeTag) !== -1;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (statusEl) {
        if (activeTag) {
          statusEl.textContent = '\u6807\u7b7e\u300c' + activeTag + '\u300d\u4e0b\u5171 ' + visible + ' \u7bc7\u6587\u7ae0';
          statusEl.classList.add('is-visible');
        } else {
          statusEl.classList.remove('is-visible');
        }
      }
    }

    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        activeTag = btn.getAttribute('data-tag') || '';
        btns.forEach(function(b) {
          b.classList.toggle('df-blog-filter__btn--active', b === btn);
        });
        apply();
      });
    });
  })();
</script>
