---
import Icon from './Icon.astro';
import { growthPartnerConfig } from 'virtual:dfgrow/config';

interface Props {
  /** 卡片放置位置，决定使用的文案组与次推链接 */
  placement?: 'about' | 'cases';
}

const { placement = 'about' } = Astro.props;

// ── 文案：about / cases 两组，可在配置外完全自定义 ──
const copyText = {
  about: {
    eyebrow: '合作推荐/增长支持',
    title: '如果你也想把官网做成长期获客资产',
    description:
      '本官网由登峰增长提供技术支持，登峰增长专注增长型官网、SEO/GEO与内容资产建设，帮助中国企业在搜索引擎和AI答案中被持续发现，获得更稳定的自然线索。',
  },
  cases: {
    eyebrow: '合作推荐/增长支持',
    title: '案例页只是开始，官网结构和内容体系才是长期资产',
    description:
      '本官网由登峰增长提供技术支持，如果你也需要搭建面向搜索与AI的获客官网，可以同步了解登峰增长的方法与服务，把官网、内容和线索归因放到同一条增长链路里。',
  },
}[placement];

// ── 从配置解析 UTM 与链接 ──
const {
  utm = {},
  primaryHref = 'https://dfgrow.com/',
  secondaryHref = 'https://dfgrow.com/services',
  aboutSecondaryHref,
  casesSecondaryHref = 'https://dfgrow.com/method',
  primaryLabel = '了解登峰增长',
  secondaryLabel = '查看方法与服务',
  appendUtm = true,
} = growthPartnerConfig;

const utmSource = utm.source ?? 'sczhiyu';
const utmMedium = utm.medium ?? 'referral';
const utmCampaignPrefix = utm.campaignPrefix ?? '';
// campaign 规则：前缀存在则 `${prefix}_${placement}_partner_promo`，否则保持旧行为 `${placement}_partner_promo`
const utmCampaign = utmCampaignPrefix
  ? `${utmCampaignPrefix}_${placement}_partner_promo`
  : `${placement}_partner_promo`;

/**
 * 给基础 URL 追加 UTM 参数。
 * - appendUtm=false 时不追加，直接返回原 URL
 * - 已包含 query 时合并，避免重复
 */
function withUtm(baseUrl: string): string {
  if (!appendUtm) return baseUrl;
  try {
    const url = new URL(baseUrl);
    const sp = url.searchParams;
    if (!sp.get('utm_source')) sp.set('utm_source', utmSource);
    if (!sp.get('utm_medium')) sp.set('utm_medium', utmMedium);
    if (!sp.get('utm_campaign')) sp.set('utm_campaign', utmCampaign);
    return url.toString();
  } catch {
    // 非绝对 URL（如相对路径），用字符串拼接
    const sep = baseUrl.includes('?') ? '&' : '?';
    return `${baseUrl}${sep}utm_source=${encodeURIComponent(utmSource)}&utm_medium=${encodeURIComponent(utmMedium)}&utm_campaign=${encodeURIComponent(utmCampaign)}`;
  }
}

// about 场景次推链接可单独覆盖，否则复用 secondaryHref
const aboutSecondary = aboutSecondaryHref ?? secondaryHref;
const secondaryBase = placement === 'cases' ? casesSecondaryHref : aboutSecondary;

const finalPrimaryHref = withUtm(primaryHref);
const finalSecondaryUrl = withUtm(secondaryBase);

const tags = ['增长型官网', 'SEO/GEO', '内容资产', '线索归因', '免费流量', '持续增长','品牌建设'];
---

<div class="rounded-2xl border border-brand-100 bg-[linear-gradient(135deg,#eff6ff_0%,#ffffff_100%)] p-7 md:p-8 shadow-sm">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1.2fr)_320px] lg:items-center">
    <div>
      <div class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-white px-4 py-2 text-xs font-semibold text-brand-700 shadow-sm">
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-brand-50 text-brand-600">
          <Icon name="sparkles" class="h-3.5 w-3.5" />
        </span>
        {copyText.eyebrow}
      </div>

      <h2 class="mt-5 text-xl md:text-2xl font-semibold text-ink-900 leading-tight">
        {copyText.title}
      </h2>
      <p class="mt-4 max-w-3xl text-base text-ink-600 leading-relaxed">
        {copyText.description}
      </p>

      <div class="mt-6 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full border border-brand-100 bg-white/80 px-3 py-1.5 text-sm text-ink-700">
            {tag}
          </span>
        ))}
      </div>

      <div class="mt-7 flex flex-wrap gap-3">
        <a
          href={finalPrimaryHref}
          target="_blank"
          rel="sponsored noopener noreferrer"
          class="inline-flex items-center justify-center rounded-md bg-brand-600 px-5 py-2.5 text-base font-medium text-white no-underline transition-colors hover:bg-brand-700"
          data-track="partner_promo_click"
          data-track-location={`${placement}_primary`}
        >
          {primaryLabel}
        </a>
        <a
          href={finalSecondaryUrl}
          target="_blank"
          rel="sponsored noopener noreferrer"
          class="inline-flex items-center justify-center rounded-md border border-brand-200 bg-white px-5 py-2.5 text-base font-medium text-brand-700 no-underline transition-colors hover:bg-brand-50"
          data-track="partner_promo_click"
          data-track-location={`${placement}_secondary`}
        >
          {secondaryLabel}
        </a>
      </div>
    </div>

    <aside class="rounded-xl border border-white/80 bg-white/85 p-5 shadow-sm backdrop-blur-sm">
      <div class="flex items-center gap-2 text-sm font-semibold text-brand-700">
        <Icon name="target" class="h-4 w-4" />
        <span>适合这些情况</span>
      </div>
      <ul class="mt-4 space-y-3 text-sm text-ink-700 leading-relaxed">
        <li class="flex items-start gap-3">
          <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-brand-50 text-brand-600">
            <Icon name="check" class="h-3 w-3" />
          </span>
          <span>正准备搭官网，希望一开始就按获客逻辑规划，而不是只停留在视觉展示层面。</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-brand-50 text-brand-600">
            <Icon name="check" class="h-3 w-3" />
          </span>
          <span>已经有官网，但搜索可见性、内容承接和线索转化、自然流量还比较弱。</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-brand-50 text-brand-600">
            <Icon name="check" class="h-3 w-3" />
          </span>
          <span>想把SEO/GEO、内容资产和线索归因放在一条链路里持续做。</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-brand-50 text-brand-600">
            <Icon name="check" class="h-3 w-3" />
          </span>
          <span>希望减少对付费获客的单一依赖，逐步建立长期自然获客能力和品牌资产。</span>
        </li>
      </ul>
    </aside>
  </div>
</div>
